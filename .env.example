# Database
DATABASE_URL=postgresql://rotavans:rotavans@localhost:5432/rotavans

# Redis
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JWT secrets
MANAGEMENT_JWT_SECRET=change-me-management-secret-with-32-chars
APP_JWT_SECRET=change-me-app-secret-with-32-characters

# Ports
MANAGEMENT_PORT=3000
APP_PORT=3001

# Development
DEV_AUTH_ENABLED=false
